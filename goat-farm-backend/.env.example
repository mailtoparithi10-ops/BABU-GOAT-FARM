# ──────────────────────────────────────────────
# Babu Goat Farm Management System - Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Database (PostgreSQL recommended for production; SQLite for local dev)
# Local dev (SQLite):
DATABASE_URL=sqlite:///./goatfarm.db
# Production (Vercel Postgres - auto-added by Vercel):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Security - generate a secure key for production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Initial Admin Account (created automatically on first startup)
FIRST_ADMIN_NAME=Admin
FIRST_ADMIN_EMAIL=admin@babugoatfarm.com
FIRST_ADMIN_PASSWORD=adminpassword

# CORS - comma-separated allowed origins
# Development: leave as * or http://localhost:5173
# Production: set to your Vercel domain e.g. https://babu-goat-farm.vercel.app
CORS_ORIGINS=*

# Vercel sets this automatically in production (do not set manually)
# VERCEL=1
