{
    "version": 2,
    "buildCommand": "cd goat-farm-frontend && npm install && npm run build",
    "outputDirectory": "goat-farm-frontend/dist",
    "framework": null,
    "functions": {
        "api/index.py": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index.py"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}